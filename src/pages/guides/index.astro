---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { fmt, isValidDate } from "@/lib/date.ts";
import {
  slugifyCategory,
  CATEGORY_ORDER,
  CATEGORY_DESCRIPTIONS,
} from "@/lib/slug.ts";

// Redirect legacy links like /guides/?category=Emergencies → /guides/category/emergencies
const q = Astro.url.searchParams.get("category");
if (q) {
  return Astro.redirect(`/guides/category/${slugifyCategory(q)}`, 301);
}

// Load all published guides
const guides = await getCollection("guides", ({ data }) => data?.draft !== true);

// Priority topic cards shown in the featured section
const PRIORITY_TOPICS = [
  {
    title: "Emergencies",
    description: "First aid, CPR, choking, bleeding, and when to call for help.",
    href: "/guides/category/emergencies",
    links: [
      { title: "CPR Guide", href: "/guides/cpr" },
      { title: "Choking Response", href: "/guides/choking" },
      { title: "Severe Allergic Reactions", href: "/guides/first-aid-for-severe-allergic-reactions" },
      { title: "Severe Bleeding", href: "/guides/severe-bleeding" },
    ],
    browseHref: "/guides/category/emergencies",
  },
  {
    title: "Heart & Circulation",
    description: "Heart attacks, stroke, blood pressure, atrial fibrillation, and cardiac risk.",
    href: "/guides/heart-circulation",
    links: [
      { title: "Heart Attack Response", href: "/guides/heart-attack-treatment" },
      { title: "Stroke Recognition", href: "/guides/stroke" },
      { title: "Blood Pressure at Home", href: "/guides/blood-pressure-at-home" },
      { title: "Atrial Fibrillation", href: "/guides/atrial-fibrillation" },
    ],
    browseHref: "/guides/category/heart-and-circulation",
  },
  {
    title: "Diabetes",
    description: "Type 1, Type 2, blood glucose monitoring, insulin, and everyday management.",
    href: "/guides/diabetes-hub",
    links: [
      { title: "Type 1 Diabetes", href: "/guides/type-1-diabetes" },
      { title: "Blood Glucose Monitoring", href: "/guides/blood-glucose-testing" },
      { title: "Understanding HbA1c", href: "/guides/understanding-hba1c" },
      { title: "Type 2 Diabetes", href: "/guides/type-2-diabetes" },
    ],
    browseHref: "/guides/category/diabetes",
  },
  {
    title: "Cancer",
    description: "Screening, treatment, precision oncology, survivorship, and support.",
    href: "/guides/cancer",
    links: [
      { title: "Bowel Cancer", href: "/guides/bowel-cancer" },
      { title: "Skin Cancer", href: "/guides/skin-cancer" },
      { title: "Breast Cancer", href: "/guides/breast-cancer" },
      { title: "Precision Medicine in Cancer", href: "/guides/precision-medicine-in-cancer" },
    ],
    browseHref: "/guides/category/cancer",
  },
  {
    title: "Mental Health",
    description: "Anxiety, depression, ADHD, sleep, crisis support, and evidence-based self-care.",
    href: "/guides/mental-health",
    links: [
      { title: "Mental Health Toolkit", href: "/guides/mental-health-toolkit" },
      { title: "Crisis Support", href: "/guides/mental-health-crisis-emergency" },
      { title: "Anxiety", href: "/guides/anxiety" },
      { title: "CBT for Insomnia", href: "/guides/cbt-insomnia" },
    ],
    browseHref: "/guides/category/mental-health",
  },
  {
    title: "Kidney Health",
    description: "Chronic kidney disease, stages, monitoring, medicines, dialysis, transplant, and related conditions.",
    href: "/guides/chronic-kidney-disease-hub",
    links: [
      { title: "Chronic Kidney Disease — Guide Hub", href: "/guides/chronic-kidney-disease-hub" },
      { title: "What Is Chronic Kidney Disease?", href: "/guides/what-is-chronic-kidney-disease" },
      { title: "CKD Stages Explained", href: "/guides/chronic-kidney-disease-stages-explained" },
      { title: "Managing Chronic Kidney Disease", href: "/guides/managing-chronic-kidney-disease" },
    ],
    browseHref: "/guides/category/kidney-health",
  },
];

// Build map: category -> guides
// Exclude hub/overview pages (category "Guide Hubs") from counts
const byCategory = new Map<string, typeof guides>();
for (const e of guides) {
  if (typeof e.data?.category === "string" && e.data.category.trim() === "Guide Hubs") {
    continue;
  }
  const cat = (e.data.category ?? "General Health").trim();
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(e);
}

// Order categories by preferred list, then alpha for any extras
const categories = Array.from(byCategory.keys()).sort((a, b) => {
  const ia = CATEGORY_ORDER.indexOf(a);
  const ib = CATEGORY_ORDER.indexOf(b);
  if (ia === -1 && ib === -1) return a.localeCompare(b);
  if (ia === -1) return 1;
  if (ib === -1) return -1;
  return ia - ib;
});

const MAX_VISIBLE = 5;

// Optional overrides: point some category cards to a hub page
const overrides: Record<string, string> = {
  "Mental Health": "/guides/mental-health",
  "Neurology": "/guides/brain-health-hub",
  "Heart & Circulation": "/guides/heart-circulation",
  "Vaccination": "/guides/vaccination",
  "Aging & Longevity": "/guides/aging-longevity",
  "Infectious Diseases": "/guides/infectious-disease-hub",
  "Kidney Health": "/guides/chronic-kidney-disease-hub",
};

const frontmatter = {
  title: "Health Guides — PatientGuide.io",
  description: "Browse our library of evidence-based health guides organised by topic.",
};
---

<Layout {frontmatter}>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <h1>Health Guides</h1>
        <p class="tagline">
          Evidence-based guides on conditions, treatments, and everyday health —
          written for patients, carers, and anyone wanting reliable health information.
        </p>
        <div class="cta-row">
          <a href="/ask" class="btn btn-primary">Ask a health question</a>
          <a href="#browse" class="btn btn-ghost">Browse by topic</a>
        </div>
      </div>
    </div>
  </section>

  <section class="pg-section">
    <h2 class="section-title">Key Topics</h2>
    <p class="section-subtitle">Start here for common and high-impact health areas.</p>
    <div class="priority-grid">
      {PRIORITY_TOPICS.map((topic) => (
        <article class="priority-card">
          <div class="priority-card__header">
            <h3 class="priority-card__title">
              <a href={topic.href}>{topic.title}</a>
            </h3>
          </div>
          <p class="priority-card__desc">{topic.description}</p>
          <ul class="priority-card__list">
            {topic.links.map((link) => (
              <li><a href={link.href}>{link.title}</a></li>
            ))}
          </ul>
          {topic.browseHref !== topic.href && (
            <a href={topic.browseHref} class="priority-card__browse">Browse all {topic.title} guides →</a>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="pg-section" id="browse">
    <div class="pg-section__header">
      <h2 class="pg-section__title">Browse by Category</h2>
    </div>

    <div class="pg-category-grid">
      {categories.map((cat) => {
        const list = byCategory.get(cat)!;
        const count = list.length;

        const defaultHref = `/guides/category/${slugifyCategory(cat)}`;
        const catHref = overrides[cat] ?? defaultHref;

        const sorted = list
          .slice()
          .sort(
            (a, b) =>
              +new Date((b.data.updatedDate ?? b.data.publishDate) as any) -
              +new Date((a.data.updatedDate ?? a.data.publishDate) as any)
          );

        const visible = sorted.slice(0, MAX_VISIBLE);
        const hidden = sorted.slice(MAX_VISIBLE);

        return (
          <article class="pg-category-card">
            <div class="pg-category-card__header">
              <h3 class="pg-category-card__title">
                <a href={catHref}>{cat}</a>
              </h3>
              <span class="pg-category-card__count">{count} guide{count === 1 ? "" : "s"}</span>
            </div>
            <p class="pg-category-card__description">
              {CATEGORY_DESCRIPTIONS[cat] ?? "Browse guides in this topic."}
            </p>

            <ul class="pg-category-card__list">
              {visible.map((e) => {
                const href = `/guides/${e.slug}`;
                const title = e.data.title ?? "(Untitled)";
                const d = e.data.updatedDate ?? e.data.publishDate;
                return (
                  <li>
                    <a href={href}>{title}</a>
                    {isValidDate(d) && <time class="pg-category-card__date">{fmt(d)}</time>}
                  </li>
                );
              })}
            </ul>

            {overrides[cat] && (
              <a href={defaultHref} class="pg-category-card__archive-link">Browse all {cat} guides →</a>
            )}

            {hidden.length > 0 && (
              <details class="pg-category-card__more">
                <summary>Show {hidden.length} more</summary>
                <ul class="pg-category-card__list">
                  {hidden.map((e) => {
                    const href = `/guides/${e.slug}`;
                    const title = e.data.title ?? "(Untitled)";
                    const d = e.data.updatedDate ?? e.data.publishDate;
                    return (
                      <li>
                        <a href={href}>{title}</a>
                        {isValidDate(d) && <time class="pg-category-card__date">{fmt(d)}</time>}
                      </li>
                    );
                  })}
                </ul>
              </details>
            )}
          </article>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  /* ===========================
     Hero
     =========================== */
  .hero {
    margin-block: 0.25rem 2rem;
  }

  .hero-inner {
    border: 1px solid var(--pg-border);
    border-radius: 16px;
    background: linear-gradient(180deg, var(--pg-surface), var(--pg-surface-soft));
    padding: 1.75rem 1.5rem;
  }

  .hero h1 {
    font-size: 2rem;
    line-height: 1.2;
    margin: 0 0 0.4rem;
    font-weight: 700;
    color: var(--pg-text);
  }

  .tagline {
    color: var(--pg-text-soft);
    margin: 0 0 1rem;
    max-width: 56ch;
    line-height: 1.6;
  }

  .cta-row {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.55rem 1rem;
    border-radius: 10px;
    border: 1px solid var(--pg-border);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--pg-text);
    transition: background var(--pg-transition-fast), border-color var(--pg-transition-fast);
  }

  .btn-primary {
    background: var(--pg-text);
    color: var(--pg-surface);
    border-color: var(--pg-text);
  }

  .btn-primary:hover {
    background: var(--pg-text-soft);
    border-color: var(--pg-text-soft);
    color: var(--pg-surface);
    text-decoration: none;
  }

  .btn-ghost {
    background: transparent;
  }

  .btn-ghost:hover {
    background: var(--pg-surface-muted);
    border-color: var(--pg-border-muted);
    text-decoration: none;
  }

  /* ===========================
     Section chrome
     =========================== */
  .pg-section {
    margin-top: var(--pg-space-10);
  }

  .pg-section__header {
    margin-bottom: var(--pg-space-5);
  }

  .pg-section__title {
    font-size: var(--pg-text-xl);
    font-weight: 600;
    color: var(--pg-text);
    margin: 0;
  }

  .section-title {
    font-size: var(--pg-text-xl);
    font-weight: 600;
    color: var(--pg-text);
    margin: 0 0 0.25rem;
  }

  .section-subtitle {
    font-size: var(--pg-text-sm);
    color: var(--pg-text-muted);
    margin: 0 0 1.25rem;
  }

  /* ===========================
     Priority topic cards
     =========================== */
  .priority-grid {
    display: grid;
    gap: var(--pg-space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .priority-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .priority-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .priority-card {
    background: var(--pg-surface);
    border: 1px solid var(--pg-border);
    border-radius: var(--pg-radius-xl);
    padding: var(--pg-space-5);
    transition: border-color var(--pg-transition-fast), box-shadow var(--pg-transition-fast);
  }

  .priority-card:hover {
    border-color: var(--pg-border-muted);
    box-shadow: var(--pg-shadow-sm);
  }

  .priority-card__header {
    margin-bottom: var(--pg-space-2);
  }

  .priority-card__title {
    font-size: var(--pg-text-lg);
    font-weight: 600;
    margin: 0;
  }

  .priority-card__title a {
    color: var(--pg-text);
    text-decoration: none;
  }

  .priority-card__title a:hover {
    color: var(--pg-link);
    text-decoration: underline;
  }

  .priority-card__desc {
    font-size: var(--pg-text-sm);
    color: var(--pg-text-soft);
    margin: 0 0 var(--pg-space-3);
    line-height: var(--pg-leading-relaxed);
  }

  .priority-card__list {
    margin: 0 0 var(--pg-space-3);
    padding-left: var(--pg-space-5);
    font-size: var(--pg-text-sm);
  }

  .priority-card__list li {
    margin-bottom: var(--pg-space-2);
    line-height: var(--pg-leading-snug);
  }

  .priority-card__list a {
    color: var(--pg-link);
  }

  .priority-card__list a:hover {
    color: var(--pg-link-hover);
  }

  .priority-card__browse {
    display: inline-block;
    font-size: var(--pg-text-xs);
    color: var(--pg-text-muted);
    text-decoration: none;
  }

  .priority-card__browse:hover {
    color: var(--pg-link);
    text-decoration: underline;
  }

  /* ===========================
     Category grid
     =========================== */
  .pg-category-grid {
    display: grid;
    gap: var(--pg-space-4);
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  .pg-category-card {
    background: var(--pg-surface);
    border: 1px solid var(--pg-border);
    border-radius: var(--pg-radius-xl);
    padding: var(--pg-space-5);
    transition: border-color var(--pg-transition-fast), box-shadow var(--pg-transition-fast);
  }

  .pg-category-card:hover {
    border-color: var(--pg-border-muted);
    box-shadow: var(--pg-shadow-sm);
  }

  .pg-category-card__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--pg-space-2);
    margin-bottom: var(--pg-space-2);
  }

  .pg-category-card__title {
    font-size: var(--pg-text-lg);
    font-weight: 600;
    margin: 0;
  }

  .pg-category-card__title a {
    color: var(--pg-text);
    text-decoration: none;
  }

  .pg-category-card__title a:hover {
    color: var(--pg-link);
    text-decoration: underline;
  }

  .pg-category-card__count {
    font-size: var(--pg-text-xs);
    color: var(--pg-text-muted);
    white-space: nowrap;
  }

  .pg-category-card__description {
    font-size: var(--pg-text-sm);
    color: var(--pg-text-soft);
    margin: 0 0 var(--pg-space-4);
    line-height: var(--pg-leading-relaxed);
  }

  .pg-category-card__list {
    margin: 0;
    padding-left: var(--pg-space-5);
    font-size: var(--pg-text-sm);
  }

  .pg-category-card__list li {
    margin-bottom: var(--pg-space-2);
    line-height: var(--pg-leading-snug);
  }

  .pg-category-card__list a {
    color: var(--pg-link);
  }

  .pg-category-card__date {
    color: var(--pg-text-muted);
    font-size: var(--pg-text-xs);
    margin-left: var(--pg-space-2);
  }

  .pg-category-card__more {
    margin-top: var(--pg-space-3);
  }

  .pg-category-card__more summary {
    font-size: var(--pg-text-sm);
    color: var(--pg-link);
    cursor: pointer;
  }

  .pg-category-card__more summary:hover {
    text-decoration: underline;
  }

  .pg-category-card__more .pg-category-card__list {
    margin-top: var(--pg-space-3);
  }

  .pg-category-card__archive-link {
    display: inline-block;
    margin-top: var(--pg-space-3);
    font-size: var(--pg-text-xs);
    color: var(--pg-text-muted);
    text-decoration: none;
  }

  .pg-category-card__archive-link:hover {
    color: var(--pg-link);
    text-decoration: underline;
  }
</style>
