---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isValidDate, fmt } from "@/lib/date";
import AuthorCard from "@/components/AuthorCard.astro";
import EmailSignup from "@/components/EmailSignup.astro";

// MDX components used inside guides
import StratBox from "../../components/StratBox.astro";
import EvidenceBox from "../../components/EvidenceBox.astro";

const mdxComponents = {
  StratBox,
  EvidenceBox,
  StatBox: StratBox,
};

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const { title, description, publishDate, updatedDate, category, tags } = entry.data;

// Defensive date rendering
const pubDate = isValidDate(publishDate) ? fmt(publishDate) : null;
const modDate = isValidDate(updatedDate) ? fmt(updatedDate) : null;
const showUpdated = modDate && modDate !== pubDate;

// Estimate reading time (rough: 200 words per minute)
const wordCount = entry.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const frontmatter = { title, description };

// Canonical URL
const site = Astro.site?.toString().replace(/\/+$/, "") ?? "https://patientguide.io";
const canonicalUrl = `${site}${Astro.url.pathname.replace(/\/+$/, "")}`;

// Inline category slugifier
function slugifyCategory(cat: string): string {
  return cat.trim().toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");
}

// Breadcrumb JSON-LD — 4-item when category present, 3-item fallback
const categorySlug = category ? slugifyCategory(category) : "";
const breadcrumbItems: object[] = [
  { "@type": "ListItem", "position": 1, "name": "Home", "item": `${site}/` },
  { "@type": "ListItem", "position": 2, "name": "Guides", "item": `${site}/guides/` },
];
if (categorySlug) {
  breadcrumbItems.push({ "@type": "ListItem", "position": 3, "name": category, "item": `${site}/guides/${categorySlug}/` });
  breadcrumbItems.push({ "@type": "ListItem", "position": 4, "name": title, "item": canonicalUrl });
} else {
  breadcrumbItems.push({ "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl });
}
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems,
};

// ---- FAQ JSON-LD (AUTO from body) -------------------------------------------
// Convention in MDX content:
//
// ## FAQ
//
// **Q: Question?**
// A: Answer.
//
// **Q: Question 2?**
// A: Answer 2.
//
// We extract from entry.body so authors only write FAQ once.
type FAQPair = { question: string; answer: string };

function extractFaqFromBody(body: string | undefined): FAQPair[] {
  if (!body) return [];

  // Find "## FAQ" heading and capture until next heading of same/higher level
  const faqBlockMatch = body.match(/(^|\n)##\s+FAQ\s*\n([\s\S]*?)(\n#{1,2}\s+|\n---\s*$|(?![\s\S]))/m);
  if (!faqBlockMatch) return [];

  const block = faqBlockMatch[2] ?? "";

  // Parse repeated patterns:
  // **Q: ...** (or **Q. ...**) followed by A: ...
  const pairs: FAQPair[] = [];
  const re = /\*\*Q[:\.]\s*([\s\S]*?)\*\*\s*\n\s*A:\s*([\s\S]*?)(?=\n\s*\*\*Q[:\.]|\n#{1,6}\s+|(?![\s\S]))/g;

  let m: RegExpExecArray | null;
  while ((m = re.exec(block)) !== null) {
    const q = (m[1] ?? "").replace(/\s+/g, " ").trim();
    const a = (m[2] ?? "").trim();

    if (!q || !a) continue;

    // Light cleanup: collapse whitespace; keep punctuation
    const answerClean = a.replace(/\n{3,}/g, "\n\n").trim();

    pairs.push({ question: q, answer: answerClean });
  }

  return pairs;
}

const faqPairsFromBody = extractFaqFromBody(entry.body);

// Back-compat: if you have old frontmatter faq arrays, keep them working
const rawFaq = (entry.data as any).faq as Array<{ question?: string; answer?: string; q?: string; a?: string }> | undefined;
const faqPairsFromFrontmatter: FAQPair[] =
  Array.isArray(rawFaq)
    ? rawFaq
        .map((item) => ({
          question: String(item.question ?? item.q ?? "").trim(),
          answer: String(item.answer ?? item.a ?? "").trim(),
        }))
        .filter((x) => x.question && x.answer)
    : [];

// Prefer body FAQ; fallback to frontmatter FAQ
const faqPairs = faqPairsFromBody.length ? faqPairsFromBody : faqPairsFromFrontmatter;

const faqLd = faqPairs.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqPairs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    }
  : null;
// ---------------------------------------------------------------------------

// Conservative tag → MedicalCondition mapping (fallback for guides without frontmatter schema)
const CONDITION_TAG_MAP: Array<{ match: string[]; name: string }> = [
  { match: ["alzheimers disease", "alzheimer's disease"], name: "Alzheimer's disease" },
  { match: ["parkinsons disease"], name: "Parkinson's disease" },
  { match: ["diabetes"], name: "Diabetes mellitus" },
];
const tagsLower = (Array.isArray(tags) ? tags : []).map((t: string) => t.toLowerCase().trim());
const matchedCondition =
  CONDITION_TAG_MAP.find(({ match }) => match.some((m) => tagsLower.includes(m)))?.name ?? null;

// Prefer rich frontmatter schema.medicalCondition; fall back to tag-based name lookup
const rawMedicalCondition = entry.data.schema?.medicalCondition;
const medicalConditionEntry: object | null = rawMedicalCondition?.name
  ? {
      "@type": "MedicalCondition",
      name: rawMedicalCondition.name,
      ...(rawMedicalCondition.description ? { description: rawMedicalCondition.description } : {}),
      ...(rawMedicalCondition.alternateName?.length ? { alternateName: rawMedicalCondition.alternateName } : {}),
      ...(rawMedicalCondition.riskFactors?.length
        ? { riskFactor: rawMedicalCondition.riskFactors.map((r) => ({ "@type": "MedicalRiskFactor", name: r })) }
        : {}),
      ...(rawMedicalCondition.symptoms?.length
        ? { signOrSymptom: rawMedicalCondition.symptoms.map((s) => ({ "@type": "MedicalSymptom", name: s })) }
        : {}),
      ...(rawMedicalCondition.possibleComplication?.length ? { possibleComplication: rawMedicalCondition.possibleComplication } : {}),
      ...(rawMedicalCondition.sameAs?.length ? { sameAs: rawMedicalCondition.sameAs } : {}),
    }
  : matchedCondition
  ? { "@type": "MedicalCondition", name: matchedCondition }
  : null;

// Build about field: one object, array of two, or absent
const aboutEntries: object[] = [
  ...(category ? [{ "@type": "MedicalSpecialty", name: category }] : []),
  ...(medicalConditionEntry ? [medicalConditionEntry] : []),
];
const aboutField =
  aboutEntries.length === 0
    ? {}
    : aboutEntries.length === 1
      ? { about: aboutEntries[0] }
      : { about: aboutEntries };

// MedicalWebPage JSON-LD (always emitted for guide pages)
const medicalWebPageLd = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: title,
  description: description ?? "",
  url: canonicalUrl,
  datePublished: publishDate ? String(publishDate).slice(0, 10) : undefined,
  dateModified: String(updatedDate ?? publishDate ?? "").slice(0, 10) || undefined,
  inLanguage: "en",
  isPartOf: { "@type": "WebSite", name: "PatientGuide", url: site },
  medicalAudience: { "@type": "MedicalAudience", audienceType: "Patient" },
  ...aboutField,
};
---

<Layout {frontmatter}>
  <!-- JSON-LD: Breadcrumbs -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <!-- JSON-LD: MedicalWebPage -->
  <script type="application/ld+json" set:html={JSON.stringify(medicalWebPageLd)} />

  {/* JSON-LD: FAQ (auto from body, fallback to frontmatter) */}
  {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}

  <article class="pg-article">
    <!-- Article header -->
    <header class="pg-article__header">
      {category && (
        <a href={`/guides/category/${category.toLowerCase().replace(/\s+/g, "-").replace(/&/g, "and")}`} class="pg-article__category">
          {category}
        </a>
      )}
      <h1 class="pg-article__title">{title}</h1>
      {description && <p class="pg-article__description">{description}</p>}

      <div class="pg-article__meta">
        {pubDate && (
          <span class="pg-article__date">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <time datetime={publishDate?.toString()}>{pubDate}</time>
          </span>
        )}
        {showUpdated && (
          <span class="pg-article__updated">
            Updated: <time datetime={updatedDate?.toString()}>{modDate}</time>
          </span>
        )}
        <span class="pg-article__reading-time">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {readingTime} min read
        </span>
      </div>
    </header>

    <!-- Article content -->
    <div class="pg-article__content prose">
      <Content components={mdxComponents} />
    </div>

    {entry.data.author && typeof entry.data.author === "object" && (
      <AuthorCard
        name={entry.data.author.name}
        href={entry.data.author.href}
        role={entry.data.author.role}
        updatedDate={modDate ?? undefined}
        note="This content is informational and not medical advice."
      />
    )}

    <EmailSignup />

    <!-- Article footer -->
    <footer class="pg-article__footer">
      <a href="/guides/" class="pg-btn pg-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Back to Guides
      </a>
    </footer>
  </article>
</Layout>

<style>
  .pg-article {
    max-width: var(--pg-max-width-prose);
    margin: 0 auto;
  }

  .pg-article__header {
    margin-bottom: var(--pg-space-8);
    padding-bottom: var(--pg-space-6);
    border-bottom: 1px solid var(--pg-border);
  }

  .pg-article__category {
    display: inline-block;
    font-size: var(--pg-text-sm);
    font-weight: 500;
    color: var(--pg-link);
    text-decoration: none;
    margin-bottom: var(--pg-space-3);
  }

  .pg-article__category:hover {
    text-decoration: underline;
  }

  .pg-article__title {
    font-size: var(--pg-text-3xl);
    font-weight: 700;
    line-height: var(--pg-leading-tight);
    color: var(--pg-text);
    margin: 0 0 var(--pg-space-4);
  }

  @media (min-width: 640px) {
    .pg-article__title {
      font-size: var(--pg-text-4xl);
    }
  }

  .pg-article__description {
    font-size: var(--pg-text-lg);
    color: var(--pg-text-soft);
    line-height: var(--pg-leading-relaxed);
    margin: 0 0 var(--pg-space-4);
  }

  .pg-article__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--pg-space-4);
    font-size: var(--pg-text-sm);
    color: var(--pg-text-muted);
  }

  .pg-article__date,
  .pg-article__reading-time {
    display: inline-flex;
    align-items: center;
    gap: var(--pg-space-2);
  }

  .pg-article__date svg,
  .pg-article__reading-time svg {
    opacity: 0.7;
  }

  .pg-article__updated {
    color: var(--pg-text-muted);
  }

  /* Article content inherits prose styles from global.css */
  .pg-article__content {
    line-height: var(--pg-leading-loose);
  }

  .pg-article__footer {
    margin-top: var(--pg-space-12);
    padding-top: var(--pg-space-6);
    border-top: 1px solid var(--pg-border);
  }
</style>
