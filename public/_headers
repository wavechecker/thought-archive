/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# --- Always fresh: robots & sitemaps (no-store covers both browser and Cloudflare) ---
/robots.txt
  Cache-Control: no-store

/sitemap*
  Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

# --- HTML document routes: browsers revalidate; Cloudflare edge bypassed ---
# Cloudflare-CDN-Cache-Control: no-store prevents the edge from caching HTML
# regardless of any zone-level Edge Cache TTL override. Standard Cache-Control
# is kept for browsers. Static assets below are intentionally excluded.
/
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

/about
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

/contact
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

/privacy
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

/terms
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

/guides
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

/guides/*
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

/posts
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

/posts/*
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

/ask/*
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store

# --- Static assets: long-lived, immutable (no Cloudflare-CDN-Cache-Control override) ---
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

/static/*
  Cache-Control: public, max-age=31536000, immutable
